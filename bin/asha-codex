#!/usr/bin/env bash
# asha-codex — launch OpenAI Codex CLI with Asha persona injected via CLI flag.
#
# No CODEX_HOME overlay, no parallel config tree. Plain `codex` and
# `asha-codex` share the same ~/.codex/. Persona is injected by:
#
#   1. Regenerating the merged identity file at $HOME/.cache/asha/instructions.md
#      (idempotent — only writes if sources changed; ~50ms cost)
#   2. Passing `-c model_instructions_file="..."` to codex so the persona
#      loads as the developer instructions for this launch only.
#
# This means: skills, prompts, agents, hooks, MCP, projects, sessions —
# all single-instance under ~/.codex/. Edit a plugin command MD and both
# `claude` (/session:save) and `codex` ($session-save) see the change with
# zero install steps.

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
ASHA_ROOT="$(dirname "$SCRIPT_DIR")"
MERGE_SCRIPT="$ASHA_ROOT/identity/identity-merge.sh"
INSTRUCTIONS="${ASHA_INSTRUCTIONS_FILE:-$HOME/.cache/asha/instructions.md}"

if [[ ! -x "$MERGE_SCRIPT" ]]; then
    echo "warn: identity-merge.sh missing or not executable: $MERGE_SCRIPT" >&2
    echo "warn: launching plain codex (no Asha persona)" >&2
    exec codex "$@"
fi

# Regenerate (idempotent — exits early if instructions.md is current).
if ! "$MERGE_SCRIPT" "$INSTRUCTIONS"; then
    echo "warn: identity merge failed; launching plain codex" >&2
    exec codex "$@"
fi

# Inject as a Codex config override. The -c value is parsed as TOML, so the
# string must be quoted: model_instructions_file="...".
exec codex -c "model_instructions_file=\"$INSTRUCTIONS\"" "$@"
