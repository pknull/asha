#!/usr/bin/env bash
# asha-codex — launch OpenAI Codex CLI with Asha persona via CODEX_HOME overlay.
#
# Sets CODEX_HOME=~/.codex-asha, which is a generated overlay containing:
#   - config.toml: user's main ~/.codex/config.toml + model_instructions_file
#   - instructions.md: merged identity layer (~/.asha/{soul,voice,keeper,...})
#   - skills/, prompts/, agents/: symlinks back to ~/.codex/* (inheritance)
#   - sessions/: separate session history (so persona / non-persona don't mix)
#
# The overlay is generated by `install.sh --target codex`. If it's missing or
# stale, this wrapper warns and falls back to plain codex.

OVERLAY="${CODEX_OVERLAY_HOME:-$HOME/.codex-asha}"

if [[ ! -f "$OVERLAY/config.toml" || ! -f "$OVERLAY/instructions.md" ]]; then
    echo "warn: Asha overlay not initialized at $OVERLAY" >&2
    echo "warn: run: ~/life/asha/install.sh --target codex" >&2
    echo "warn: launching plain codex (no Asha persona)" >&2
    exec codex "$@"
fi

export CODEX_HOME="$OVERLAY"
exec codex "$@"
