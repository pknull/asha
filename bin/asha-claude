#!/usr/bin/env bash
# asha-claude — launch Claude Code with Asha persona at system-prompt level.
#
# Two mechanisms work together:
#   1. ASHA_PERSONA=1 tells the SessionStart hook to load soul/voice/keeper
#   2. --append-system-prompt-file injects the identity assertion at
#      system-prompt priority (highest)
#
# Falls back to plain claude if identity file is missing.
#
# This wrapper ships with the asha repo. The bin installer (install.sh --bin
# claude) places ~/.local/bin/asha → here. The legacy ~/bin/asha (in dotfiles)
# is retired by install.sh after detection.

# Resolve this script's dir, following symlinks. Portable (no GNU `readlink -f`;
# this wrapper is invoked via the ~/.local/bin/asha symlink).
__asha_src="${BASH_SOURCE[0]}"
while [ -h "$__asha_src" ]; do
  __asha_dir="$(cd -P "$(dirname "$__asha_src")" >/dev/null 2>&1 && pwd)"
  __asha_src="$(readlink "$__asha_src")"
  case "$__asha_src" in /*) ;; *) __asha_src="$__asha_dir/$__asha_src" ;; esac
done
SCRIPT_DIR="$(cd -P "$(dirname "$__asha_src")" >/dev/null 2>&1 && pwd)"
unset __asha_src __asha_dir
ASHA_ROOT="$(dirname "$SCRIPT_DIR")"
IDENTITY_FILE="$ASHA_ROOT/identity/asha-identity-system-prompt.md"

# Load Asha-scoped secrets/env (~/.asha/secrets.env if present). Sourcing
# here, not in the user's shell rc, keeps tokens out of unrelated subprocess
# environments. See docs/secrets.md.
# shellcheck source=./asha-env-bootstrap.sh
source "$SCRIPT_DIR/asha-env-bootstrap.sh"

export ASHA_PERSONA=1

# Management subcommands (claude <subcommand>) run their own TUIs / one-shot
# helpers that DO NOT start a model session. Injecting --append-system-prompt-file
# forces them out of TTY mode (e.g. `claude agents` falls back to a plain text
# dump instead of the interactive agent dashboard). Pass through cleanly for
# these — the persona flag is only meaningful for session launches.
case "${1:-}" in
    agents|auth|auto-mode|doctor|install|mcp|plugin|plugins|project|setup-token|ultrareview|update|upgrade)
        exec claude "$@"
        ;;
esac

if [[ -f "$IDENTITY_FILE" ]]; then
    exec claude --append-system-prompt-file "$IDENTITY_FILE" "$@"
else
    echo "warn: Asha identity file not found at $IDENTITY_FILE" >&2
    echo "warn: Persona will load via hook only (lower priority)" >&2
    exec claude "$@"
fi
