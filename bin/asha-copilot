#!/usr/bin/env bash
# Asha → GitHub Copilot CLI wrapper.
#
# Bootstraps Asha identity merge + secrets, regenerates the merged identity
# file, then exec's `copilot`. Persona injection mechanism: Copilot CLI 1.0.x
# does NOT have an --instructions-file flag (verified empirically against
# `copilot --help` 2026-05-09). The advertised mechanism is auto-loading of
# project-scope AGENTS.md and .github/copilot-instructions.md.
#
# This wrapper therefore takes a deliberately minimal stance:
#   1. Regenerate $INSTRUCTIONS_PATH (merged Asha identity) so the user has it
#      available to source manually or install into their project's AGENTS.md.
#   2. Log a one-line pointer to the merged identity file path.
#   3. Exec `copilot` plain. If you want Asha persona loaded for a project,
#      `copilot init` once in that project, then concatenate the merged
#      identity into the generated .github/copilot-instructions.md, or copy
#      to AGENTS.md at project root.
#
# Override entry binary: ASHA_COPILOT_CMD=gh-copilot asha-copilot
# Override merged identity path: ASHA_COPILOT_INSTRUCTIONS_FILE=/path asha-copilot

set -euo pipefail

# Resolve this script's dir, following symlinks. Portable (no GNU `readlink -f`).
__asha_src="${BASH_SOURCE[0]}"
while [ -h "$__asha_src" ]; do
  __asha_dir="$(cd -P "$(dirname "$__asha_src")" >/dev/null 2>&1 && pwd)"
  __asha_src="$(readlink "$__asha_src")"
  case "$__asha_src" in /*) ;; *) __asha_src="$__asha_dir/$__asha_src" ;; esac
done
SCRIPT_DIR="$(cd -P "$(dirname "$__asha_src")" >/dev/null 2>&1 && pwd)"
unset __asha_src __asha_dir
ASHA_ROOT="$(dirname "$SCRIPT_DIR")"
# Cross-platform shims (resolve_path) for the persona-wiring check below.
# shellcheck source=../lib/portable.sh
source "$ASHA_ROOT/lib/portable.sh"
MERGE_SCRIPT="$ASHA_ROOT/identity/identity-merge.sh"
INSTRUCTIONS_PATH="${ASHA_COPILOT_INSTRUCTIONS_FILE:-$HOME/.cache/asha/instructions-copilot.md}"

# Allow user to override the entry binary (`copilot` vs `gh copilot`, etc.).
_COPILOT_CMD="${ASHA_COPILOT_CMD:-copilot}"

# Load Asha-scoped secrets/env (~/.asha/secrets.env if present). Sourcing
# here, not in the user's shell rc, keeps tokens out of unrelated subprocess
# environments. See docs/secrets.md.
# shellcheck source=./asha-env-bootstrap.sh
source "$SCRIPT_DIR/asha-env-bootstrap.sh"

# Parity with asha-claude: signal to any SessionStart-style hook that this
# launch wants the Asha persona loaded.
export ASHA_PERSONA=1

if [[ ! -x "$MERGE_SCRIPT" ]]; then
    echo "warn: identity-merge.sh missing or not executable: $MERGE_SCRIPT" >&2
    echo "warn: launching plain $_COPILOT_CMD (no Asha persona)" >&2
    exec "$_COPILOT_CMD" "$@"
fi

# Regenerate the merged identity file (idempotent — exits early if current).
if ! "$MERGE_SCRIPT" "$INSTRUCTIONS_PATH"; then
    echo "warn: identity merge failed; launching plain $_COPILOT_CMD" >&2
    exec "$_COPILOT_CMD" "$@"
fi

# Persona injection: Copilot CLI 1.0.x has no --instructions-file flag.
# It auto-loads project-scope AGENTS.md and .github/copilot-instructions.md
# (verified empirically 2026-05-09). The merged identity at $INSTRUCTIONS_PATH
# is regenerated above; the user must wire it into one of those project-scope
# files. Detect the current project's state and print a targeted hint.

_PROJECT_COPILOT_INSTR="$PWD/.github/copilot-instructions.md"
_PROJECT_AGENTS="$PWD/AGENTS.md"

if [[ -L "$_PROJECT_COPILOT_INSTR" ]] \
   && [[ "$(resolve_path "$_PROJECT_COPILOT_INSTR")" == "$(resolve_path "$INSTRUCTIONS_PATH")" ]]; then
    # Symlinked to the cached identity — fully wired. Stay quiet.
    echo "[asha-copilot] persona: wired via .github/copilot-instructions.md → cache" >&2

elif [[ -e "$_PROJECT_COPILOT_INSTR" ]] || [[ -e "$_PROJECT_AGENTS" ]]; then
    # Project has an instructions file but it isn't a symlink to ours. Could
    # be user-curated, could be a stale copy, could be a multi-tool AGENTS.md.
    # Don't presume; just note where the fresh merged identity lives.
    echo "[asha-copilot] persona: project has its own instructions file" >&2
    echo "[asha-copilot]   if it should pick up updated Asha identity, regenerate from:" >&2
    echo "[asha-copilot]   $INSTRUCTIONS_PATH" >&2

else
    # Fresh project — neither file exists. Refuse to launch (strict-fail).
    #
    # Rationale: asha-copilot launches Copilot WITH Asha persona. If persona
    # can't be loaded (Copilot v1.0.x has no flag-level injection), running
    # anyway is silent vanilla Copilot that LOOKS like asha-copilot succeeded.
    # The wrapper has one job; if it can't do it, the user runs plain
    # `copilot` instead. No escape hatch — pure contract.
    #
    # The hint must be visible BEFORE Copilot's TUI takes over the screen —
    # exit 1 leaves it at the shell prompt where the user can read and act.
    cat >&2 <<EOF
[asha-copilot] persona: NOT wired in this project

asha-copilot launches Copilot WITH Asha persona, but Copilot CLI v1.0.x
has no --instructions-file flag. Persona must be wired via a project-scope
file. To do it once for this project:

  mkdir -p .github
  ln -s $INSTRUCTIONS_PATH \\
    .github/copilot-instructions.md
  echo '.github/copilot-instructions.md' >> .gitignore

Then re-run: asha-copilot

To verify it worked, look for "2 custom instructions" in the startup banner:
  Environment loaded: 2 custom instructions, 45 skills, 1 MCP server, ...

If you don't want persona, run plain \`copilot\` — asha-copilot is the
wrapper that exists to load persona; without it there's nothing it adds
that plain \`copilot\` doesn't already do.

Persona injection is upstream-blocked on Copilot v1.0.x. When v1.1+ ships
an instructions-file flag, this manual step goes away.
EOF
    exit 1
fi

exec "$_COPILOT_CMD" "$@"
