{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pknull.dev/asha/harness-capabilities.schema.json",
  "type": "object",
  "required": ["schema_version", "reviewed", "principle", "harnesses"],
  "additionalProperties": false,
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": 3},
    "reviewed": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "principle": {"type": "string", "minLength": 1},
    "harnesses": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"$ref": "#/$defs/harness"}
    }
  },
  "$defs": {
    "harness": {
      "type": "object",
      "required": ["executable", "home_env", "capabilities"],
      "additionalProperties": false,
      "properties": {
        "executable": {"type": "string", "minLength": 1},
        "home_env": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*_HOME$"},
        "capabilities": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"$ref": "#/$defs/capability"}
        }
      }
    },
    "capability": {
      "type": "object",
      "required": ["support", "surface", "verifier", "limitations"],
      "additionalProperties": false,
      "properties": {
        "support": {"enum": ["native", "rendered", "partial", "unsupported"]},
        "surface": {"type": "string"},
        "verifier": {"type": "string"},
        "limitations": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
