{
  "version": 2,
  "reviewed": "2026-07-11",
  "principle": "Same intent, native harness surfaces. Unsupported capabilities are named, not simulated.",
  "harnesses": {
    "claude": {
      "commands": {
        "status": "native",
        "surface": "~/.claude/commands/<namespace>/<command>.md"
      },
      "skills": {
        "status": "native",
        "surface": "~/.claude/skills/<name>/SKILL.md"
      },
      "agents": {
        "status": "native_markdown",
        "surface": "~/.claude/agents/<namespace>/<agent>.md"
      },
      "hooks": {
        "status": "enforced",
        "surface": "~/.claude/settings.json"
      },
      "guardrails": {
        "status": "content_aware_hooks"
      },
      "persona": {
        "status": "append_system_prompt_file"
      }
    },
    "codex": {
      "instructions": {
        "status": "native_hierarchical",
        "surface": "AGENTS.md and AGENTS.override.md"
      },
      "commands": {
        "status": "rendered_as_skills",
        "surface": "~/.codex/skills/<command-name>/SKILL.md",
        "note": "Codex has built-in slash commands but no documented user-defined slash-command file surface."
      },
      "skills": {
        "status": "native_compatible",
        "surface": "~/.codex/skills/<skill-name>/SKILL.md",
        "documented_authoring_surface": "$HOME/.agents/skills/<skill-name>/SKILL.md",
        "note": "The Asha install path is verified by this Codex environment; current public documentation names $HOME/.agents/skills as the canonical user authoring location."
      },
      "agents": {
        "status": "native_toml",
        "surface": "~/.codex/agents/<namespace>-<agent>.toml"
      },
      "hooks": {
        "status": "native_partial_guardrail",
        "surface": "~/.codex/config.toml",
        "documented_coverage": [
          "simple Bash calls",
          "apply_patch",
          "MCP tool calls"
        ],
        "documented_gaps": [
          "some unified_exec shell calls",
          "WebSearch and other non-shell non-MCP tools"
        ],
        "note": "Non-managed hooks require trust. Matching hooks run concurrently. Hooks are not a complete enforcement boundary."
      },
      "guardrails": {
        "status": "partial_hooks_plus_native_rules",
        "surface": "~/.codex/config.toml and ~/.codex/rules/asha.rules",
        "note": "Rules are prefix-based and govern commands requesting execution outside the sandbox."
      },
      "persona": {
        "status": "model_instructions_file",
        "note": "Wrapper-scoped replacement instruction file; repository AGENTS.md remains the durable project guidance surface."
      },
      "plugins": {
        "status": "native_available_not_used_by_direct_installer",
        "surface": ".codex-plugin/plugin.json",
        "supports": [
          "skills",
          "hooks",
          "MCP servers",
          "apps/connectors",
          "assets"
        ]
      }
    },
    "copilot": {
      "commands": {
        "status": "rendered_as_skills",
        "surface": "~/.copilot/skills/<command-name>/SKILL.md"
      },
      "skills": {
        "status": "native",
        "surface": "~/.copilot/skills/<skill-name>/SKILL.md"
      },
      "agents": {
        "status": "native_agent_md",
        "surface": "~/.copilot/agents/<namespace>-<agent>.agent.md"
      },
      "hooks": {
        "status": "adapter_enforced_with_concurrency_caveat",
        "surface": "~/.copilot/hooks/asha-guardrails.json"
      },
      "guardrails": {
        "status": "content_aware_adapter_soft_deterrent"
      },
      "persona": {
        "status": "custom_instructions_dir"
      }
    }
  }
}
